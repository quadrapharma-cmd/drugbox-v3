# ============================================================
# Drugbox — Environment Variables
# Copy to .env.local and fill in real values before running.
# ============================================================

# --- Supabase (required) ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# ⚠️ SERVER-ONLY — never expose to the browser. Used for seeding & admin tasks.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# --- Upstash Redis (required for rate limiting in production) ---
# From Upstash console: REST API section
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
